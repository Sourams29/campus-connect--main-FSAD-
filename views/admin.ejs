    <title>Admin - Event Management</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="icon" type="image/png" href="image\favicon.ico">

    <style>
        /* General Styles */
        body {
            font-family: Arial, sans-serif;
            background-color: #e9f5f2;
            margin: 0;
            padding: 0;
            color: #333;
        }

